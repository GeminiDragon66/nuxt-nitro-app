# Supabase Configuration
# Get these from your Supabase project dashboard: Settings > API Keys
# Use the new publishable/secret keys or legacy anon/service_role keys

# Required - Your Supabase project URL
NUXT_SUPABASE_URL=https://your-project-id.supabase.co

# Client-side (public) - Use the publishable key or legacy anon key
NUXT_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-side (private) - Use the secret key or legacy service_role key
NUXT_SUPABASE_SERVICE_KEY=your-service-role-or-secret-key
